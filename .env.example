# ─────────────────────────────────────────────────────────────
# Food Store — Backend (FastAPI)  ·  copiar a .env y completar
#   cp .env.example .env
# NUNCA commitear el .env real con tokens verdaderos.
# ─────────────────────────────────────────────────────────────

# ── Base de datos (PostgreSQL) ───────────────────────────────
# Formato: postgresql+psycopg2://USER:PASS@HOST:PUERTO/DB
DATABASE_URL=postgresql+psycopg2://postgres@localhost:5432/parcial

# ── JWT / Auth ───────────────────────────────────────────────
# SECRET_KEY: mínimo 32 chars. Generar uno propio, p.ej.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-de-32-chars-o-mas
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Cloudinary (gestión de imágenes) ─────────────────────────
# Dashboard → Settings → API Keys.
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ── MercadoPago (Checkout PRO) ───────────────────────────────
# Credenciales de la app de PRUEBA: https://www.mercadopago.com.ar/developers/panel
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Secreto para validar la firma del webhook IPN (opcional).
MP_WEBHOOK_SECRET=
# URL pública del webhook IPN (necesita exponer el backend, p.ej. ngrok).
# Sin esto, el pago NO se auto-confirma a CONFIRMADO al pagar.
MP_NOTIFICATION_URL=https://tu-dominio-ngrok.com/api/v1/pagos/webhook

# ── Frontend ─────────────────────────────────────────────────
# URL del storefront, usada para las back_urls del Checkout PRO.
FRONTEND_URL=http://localhost:5173

# Nota WebSocket: el WS (/api/v1/pedidos/ws) se autentica con la misma
# cookie httpOnly del login; no necesita variables aparte. CORS ya permite
# cualquier puerto de localhost/127.0.0.1 con credenciales (ver app/main.py).
